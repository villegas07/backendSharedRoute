# ──────────────────────────────────────────────
# SharedRoute API — Variables de entorno
# Copia este archivo a .env y completa los valores
# cp .env.example .env
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_EXTERNAL_PORT=5434
DB_USERNAME=sharedroute
DB_PASSWORD=sharedroute_secret
DB_NAME=sharedroute_db

# ── JWT ──────────────────────────────────────
# ⚠️  Cambia estos valores en producción (openssl rand -hex 64)
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6380
REDIS_TTL=300

# ── Google Maps ──────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_LANGUAGE=es
GOOGLE_MAPS_REGION=co

# ── Wompi (Pasarela de pago) ─────────────────
# Obtén tus claves en https://dashboard.wompi.co
WOMPI_PUBLIC_KEY=pub_test_your_public_key_here
WOMPI_PRIVATE_KEY=prv_test_your_private_key_here
WOMPI_EVENTS_SECRET=your_events_secret_here
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_CURRENCY=COP
