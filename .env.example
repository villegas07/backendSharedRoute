# ──────────────────────────────────────────────
# SharedRoute API — Variables de entorno
# Copia este archivo a .env y completa los valores
# cp .env.example .env
# ──────────────────────────────────────────────

# ── App ──────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_EXTERNAL_PORT=5434
DB_USERNAME=sharedroute
DB_PASSWORD=sharedroute_secret
DB_NAME=sharedroute_db

# ── JWT ──────────────────────────────────────
# ⚠️  Cambia estos valores en producción (openssl rand -hex 64)
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6380
REDIS_TTL=300

# ── Google Maps ──────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_LANGUAGE=es
GOOGLE_MAPS_REGION=co
